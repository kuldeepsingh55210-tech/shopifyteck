# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopify_ai_support

# When running with Docker Compose, HOST should be the service name:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/shopify_ai_support

POSTGRES_PASSWORD=postgres

# ─── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Shopify OAuth ────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# ─── Token Encryption ─────────────────────────────────────────────────────────
# Must be a 32-byte (64 hex char) random string. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your_64_hex_char_string_here

# ─── App ──────────────────────────────────────────────────────────────────────
# URL where this backend is publicly accessible (for Shopify OAuth redirect)
APP_URL=http://localhost:3000
